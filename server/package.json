{
  "name": "udemy-dashboard-server",
  "version": "1.0.0",
  "description": "Backend proxy for the Udemy Instructor API",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test:auth": "node testAuth.js",
    "scrape:enrollment": "node scrapeEnrollment.js",
    "scrape:transcripts": "node scrapeTranscripts.js",
    "auth:udemy": "node captureAuth.js",
    "import:cookies": "node importCookies.js",
    "scrape:revenue": "node scrapeRevenue.js",
    "scrape:captions": "node scrapeCaptions.js",
    "scrape:coupons": "node scrapeCoupons.js",
    "coursera:courses": "node scrapeCourseraCourses.js",
    "coursera:overview": "node scrapeCourseraOverview.js",
    "coursera:metrics": "node scrapeCourseraMetrics.js",
    "discover": "node discover.js",
    "update": "node update-all.js",
    "captions:files": "node scrapeCaptionFiles.js",
    "translate": "node translateVtt.js",
    "captions:upload": "node uploadCaptions.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "playwright": "^1.61.1"
  }
}
