# Copy this file to ".env" and fill in your real key.
# Get your key from https://www.udemy.com/instructor/account/api/
# It is sent as a Bearer token — a single key is all you need.

UDEMY_API_KEY=your_api_key_here

# Port the backend listens on
PORT=5055

# Access control. Leave DASHBOARD_PASSWORD blank locally (open);
# set it in production to require login (HTTP basic auth).
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=
